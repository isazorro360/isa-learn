rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isBootstrapAdmin() {
      return request.auth != null && request.auth.token.email in ['admin@isaitech.com'];
    }

    function isUserAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles is list
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    function isAdmin() {
      return isBootstrapAdmin() || isUserAdmin();
    }

    match /past_questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.roles is list
        && request.resource.data.roles.size() > 0
        && request.resource.data.email is string
        && request.resource.data.displayName is string;
      allow update: if request.auth != null && (
        (request.auth.uid == userId
          && request.resource.data.roles == resource.data.roles
          && request.resource.data.email == resource.data.email)
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /bookmarks/{bookmarkId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.resourceId is string
        && request.resource.data.title is string
        && request.resource.data.subject is string
        && request.resource.data.category is string
        && request.resource.data.year is int
        && request.resource.data.fileUrl is string
        && request.resource.data.fileName is string;

      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && request.query.where('userId', '==', request.auth.uid);
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
